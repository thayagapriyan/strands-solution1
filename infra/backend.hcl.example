# One-time manual setup:
#   1. Create an S3 bucket in your AWS account (enable versioning + encryption)
#   2. Copy this file to infra/backend.hcl and fill in your bucket name
#   3. Run: cd infra && terraform init -backend-config=backend.hcl
#
# backend.hcl is gitignored — only backend.hcl.example is committed.
# Locking uses S3 natively (use_lockfile) — no DynamoDB table needed.

bucket       = "your-s3-bucket-name"
key          = "warewise/terraform.tfstate"
region       = "us-east-1"
encrypt      = true
use_lockfile = true
